# ============================================================================
# BidWorks MVP Environment Configuration Variables
# File: .env.example
# ============================================================================

# 1. AI Studio Platform Injected Variables
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# 2. General Express Server Configuration
APP_ENV=development
APP_PORT=3000
LOG_LEVEL=info

# 3. Security and JWT Signatures
JWT_SECRET=bidworks-jwt-signature-secret-key

# 4. Storage and DB Drivers
# Target production and pilot database (PostgreSQL is MANDATORY for pilot & production!):
DATABASE_URL=postgresql://bidworks_user:password@localhost:5432/bidworks_mvp
# SQLite Local dev fallback (ONLY permitted in development APP_ENV!):
# DATABASE_URL=sqlite://./bidworks.sqlite
FILE_STORAGE_PATH=./storage

# 5. Pluggable AI Models Settings (bailian | mock)
AI_PROVIDER=bailian

# 阿里云百炼 / DashScope 官方大文件 API 密钥配置 (任选其一，推荐 DASHSCOPE_API_KEY)
DASHSCOPE_API_KEY=
BAILIAN_API_KEY=

# 百炼模型服务终结点与模型设定
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-long

# 备用模型，可选
BAILIAN_FALLBACK_MODEL=qwen-plus

# AI 调用控制
AI_ENABLE_SENSITIVE_READ=false
AI_REQUEST_TIMEOUT_MS=120000
AI_MAX_INPUT_CHUNKS=20
AI_MAX_OUTPUT_TOKENS=4096
